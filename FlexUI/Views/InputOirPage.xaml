<?xml version="1.0" encoding="utf-8" ?>
<Page
  x:Class="FlexID.Views.InputOirPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:i="using:Microsoft.Xaml.Interactivity"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:v="using:FlexID.Views"
  xmlns:vb="using:FlexID.Views.Behaviors"
  xmlns:vm="using:FlexID.ViewModels"
  HorizontalAlignment="Stretch"
  VerticalAlignment="Stretch"
  d:DataContext="{d:DesignInstance vm:InputOirViewModel}"
  NavigationCacheMode="Required"
  mc:Ignorable="d">

  <Page.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
  </Page.Resources>

  <Grid Margin="16" RowSpacing="24">
    <Grid.RowDefinitions>
      <RowDefinition />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <v:InputsPage Grid.Row="0" Targets="{x:Bind ViewModel.Targets}" />

    <Grid
      Grid.Row="1"
      RowSpacing="16"
      ColumnSpacing="8"
      KeyTipPlacementMode="Left">

      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="160" />
        <ColumnDefinition />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
      </Grid.RowDefinitions>

      <Grid.Resources>
        <Style BasedOn="{StaticResource DefaultButtonStyle}" TargetType="Button">
          <Setter Property="VerticalAlignment" Value="Stretch" />
          <Setter Property="Content" Value="Browse" />
        </Style>
      </Grid.Resources>

      <TextBlock
        Grid.Row="0"
        Grid.Column="0"
        Text="Commitment Period" />
      <StackPanel
        Grid.Row="0"
        Grid.Column="1"
        Grid.ColumnSpan="2"
        Spacing="8"
        Orientation="Horizontal">
        <TextBox
          Width="100"
          HorizontalContentAlignment="Center"
          AccessKey="P"
          Text="{x:Bind ViewModel.CommitmentPeriod, Mode=TwoWay}" />
        <ComboBox
          Width="120"
          VerticalAlignment="Stretch"
          IsEditable="False"
          IsTextSearchEnabled="True"
          ItemsSource="{x:Bind ViewModel.CommitmentPeriodUnits}"
          SelectedValue="{x:Bind ViewModel.SelectedCommitmentPeriodUnit, Mode=TwoWay}" />
      </StackPanel>

      <TextBlock
        Grid.Row="1"
        Grid.Column="0"
        Text="Computational Time Mesh" />
      <TextBox
        Grid.Row="1"
        Grid.Column="1"
        AccessKey="TC"
        Text="{x:Bind ViewModel.ComputeTimeMeshFilePath, Mode=TwoWay}">
        <i:Interaction.Behaviors>
          <vb:PathDropBehavior AllowDropPath="SingleAny" DropCommand="{x:Bind ViewModel.SelectComputeTimeMeshFilePathCommand}" />
          <vb:PathPasteBehavior />
        </i:Interaction.Behaviors>
      </TextBox>
      <Button
        Grid.Row="1"
        Grid.Column="2"
        Command="{x:Bind ViewModel.SelectComputeTimeMeshFilePathCommand}" />

      <TextBlock
        Grid.Row="2"
        Grid.Column="0"
        Text="Output Time Mesh" />
      <TextBox
        Grid.Row="2"
        Grid.Column="1"
        AccessKey="TO"
        Text="{x:Bind ViewModel.OutputTimeMeshFilePath, Mode=TwoWay}">
        <i:Interaction.Behaviors>
          <vb:PathDropBehavior AllowDropPath="SingleAny" DropCommand="{x:Bind ViewModel.SelectOutputTimeMeshFilePathCommand}" />
          <vb:PathPasteBehavior />
        </i:Interaction.Behaviors>
      </TextBox>
      <Button
        Grid.Row="2"
        Grid.Column="2"
        Command="{x:Bind ViewModel.SelectOutputTimeMeshFilePathCommand}" />

      <TextBlock
        Grid.Row="3"
        Grid.Column="0"
        Text="Output Directory" />
      <TextBox
        Grid.Row="3"
        Grid.Column="1"
        AccessKey="O"
        Text="{x:Bind ViewModel.OutputDirectory, Mode=TwoWay}">
        <i:Interaction.Behaviors>
          <vb:PathDropBehavior AllowDropPath="SingleAny" DropCommand="{x:Bind ViewModel.SelectOutputDirectoryCommand}" />
          <vb:PathPasteBehavior />
        </i:Interaction.Behaviors>
      </TextBox>
      <Button
        Grid.Row="3"
        Grid.Column="2"
        Command="{x:Bind ViewModel.SelectOutputDirectoryCommand}" />
    </Grid>

    <Button
      Grid.Row="2"
      Width="128"
      Height="40"
      Margin="0,0,24,0"
      HorizontalAlignment="Right"
      Command="{x:Bind ViewModel.RunCommand}"
      Content="Run" />
  </Grid>

</Page>
