      <RowDefinition Height="Auto" SharedSizeGroup="R" />
      <RowDefinition />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Label
      Grid.Row="1"
      Grid.Column="0"
      Content="Nuclide" />
    <ComboBox
      Grid.Row="1"
      Grid.Column="1"
      ItemsSource="{Binding Nuclides}"
      SelectedValue="{Binding SelectedNuclide}" />

    <Label
      Grid.Row="2"
      Grid.Column="0"
