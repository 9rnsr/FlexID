<?xml version="1.0" encoding="utf-8" ?>
<Page
  x:Class="FlexID.Views.InputScoeffPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors"
  xmlns:controls="using:CommunityToolkit.WinUI.Controls"
  xmlns:converters="using:CommunityToolkit.WinUI.Converters"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:i="using:Microsoft.Xaml.Interactivity"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:v="using:FlexID.Views"
  xmlns:vb="using:FlexID.Views.Behaviors"
  xmlns:vm="using:FlexID.ViewModels"
  HorizontalAlignment="Stretch"
  VerticalAlignment="Stretch"
  d:DataContext="{d:DesignInstance vm:InputScoeffViewModel}"
  NavigationCacheMode="Required"
  mc:Ignorable="d">

  <Page.Resources>
    <Style BasedOn="{StaticResource DefaultCheckBoxStyle}" TargetType="CheckBox">
      <Setter Property="Margin" Value="32,4" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <Style BasedOn="{StaticResource DefaultRadioButtonStyle}" TargetType="RadioButton">
      <Setter Property="Margin" Value="32,4" />
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <converters:BoolNegationConverter x:Key="Inverted" />
  </Page.Resources>

  <Grid Margin="16" RowSpacing="24">
    <Grid.RowDefinitions>
      <RowDefinition />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid
      Grid.Row="0"
      RowSpacing="8"
      ColumnSpacing="8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition />
      </Grid.RowDefinitions>

      <TextBlock Grid.Row="0" Text="Target Nuclides" />
      <Grid Grid.Row="1" MinHeight="64">
        <GridView
          x:Name="NuclidesView"
          Padding="12,8"
          ItemsSource="{x:Bind ViewModel.Nuclides.FilteredItems}"
          SelectionMode="Extended">

          <GridView.ItemsPanel>
            <ItemsPanelTemplate>
              <ItemsWrapGrid ItemHeight="48" Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </GridView.ItemsPanel>

          <GridView.ItemTemplate>
            <DataTemplate x:DataType="vm:NuclideViewModel">
              <StackPanel
                Width="96"
                Margin="6,0"
                Orientation="Horizontal">
                <CheckBox
                  MinWidth="0"
                  Margin="0"
                  IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                  IsTabStop="False" />
                <TextBlock
                  Padding="0,0,0,2"
                  VerticalAlignment="Center"
                  Text="{x:Bind Nuclide}" />
              </StackPanel>
            </DataTemplate>
          </GridView.ItemTemplate>
        </GridView>
      </Grid>
    </Grid>

    <Grid
      Grid.Row="1"
      RowSpacing="16"
      ColumnSpacing="8"
      KeyTipPlacementMode="Left">

      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="160" />
        <ColumnDefinition />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <Grid.RowDefinitions>
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
        <RowDefinition />
      </Grid.RowDefinitions>

      <Grid.Resources>
        <Style BasedOn="{StaticResource DefaultButtonStyle}" TargetType="Button">
          <Setter Property="VerticalAlignment" Value="Stretch" />
          <Setter Property="Content" Value="Browse" />
        </Style>
      </Grid.Resources>

      <TextBlock
        Grid.Row="0"
        Grid.Column="0"
        Text="Sex" />
      <controls:UniformGrid
        Grid.Row="0"
        Grid.Column="1"
        HorizontalAlignment="Center"
        Columns="2">
        <CheckBox
          Grid.Column="0"
          AccessKey="AM"
          Content="Adult Male"
          IsChecked="{x:Bind ViewModel.CalcMale, Mode=TwoWay}" />
        <CheckBox
          Grid.Column="1"
          AccessKey="AF"
          Content="Adult Female"
          IsChecked="{x:Bind ViewModel.CalcFemale, Mode=TwoWay}" />
      </controls:UniformGrid>

      <TextBlock
        Grid.Row="1"
        Grid.Column="0"
        Text="SAF Interpolation" />
      <controls:UniformGrid
        Grid.Row="1"
        Grid.Column="1"
        HorizontalAlignment="Center"
        Columns="2">
        <RadioButton
          Grid.Column="0"
          AccessKey="P"
          Content="PCHIP"
          IsChecked="{x:Bind ViewModel.CalcPchip, Mode=TwoWay}" />
        <RadioButton
          Grid.Column="1"
          AccessKey="L"
          Content="Linear"
          IsChecked="{x:Bind ViewModel.CalcPchip, Mode=TwoWay, Converter={StaticResource Inverted}}" />
      </controls:UniformGrid>

      <TextBlock
        Grid.Row="2"
        Grid.Column="0"
        Text="Output Format" />
      <Grid
        Grid.Row="2"
        Grid.Column="1"
        HorizontalAlignment="Center">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <RadioButton
          Grid.Column="0"
          Margin="16,4"
          AccessKey="F1"
          Content="FlexID (*.txt)"
          IsChecked="{x:Bind ViewModel.IdacDoseCompatible, Mode=TwoWay, Converter={StaticResource Inverted}}" />
        <RadioButton
          Grid.Column="1"
          Margin="16,4"
          AccessKey="F2"
          Content="IDAC-Dose 2.1 compatible (*.csv)"
          IsChecked="{x:Bind ViewModel.IdacDoseCompatible, Mode=TwoWay}" />
      </Grid>

      <TextBlock
        Grid.Row="3"
        Grid.Column="0"
        Text="Output Directory" />
      <TextBox
        Grid.Row="3"
        Grid.Column="1"
        AccessKey="O"
        Text="{x:Bind ViewModel.OutputDirectory, Mode=TwoWay}">
        <i:Interaction.Behaviors>
          <vb:PathDropBehavior AllowDropPath="SingleAny" DropCommand="{x:Bind ViewModel.SelectOutputDirectoryCommand}" />
          <vb:PathPasteBehavior />
        </i:Interaction.Behaviors>
      </TextBox>
      <Button
        Grid.Row="3"
        Grid.Column="2"
        Command="{x:Bind ViewModel.SelectOutputDirectoryCommand}" />
    </Grid>

    <Button
      Grid.Row="2"
      Width="128"
      Height="40"
      Margin="0,8,24,0"
      HorizontalAlignment="Right"
      Command="{x:Bind ViewModel.RunCommand}"
      Content="Run" />
  </Grid>

</Page>
