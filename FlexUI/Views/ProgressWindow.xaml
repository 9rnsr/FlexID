<?xml version="1.0" encoding="utf-8" ?>
<winex:WindowEx
  x:Class="FlexID.Views.ProgressWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:v="using:FlexID.Views"
  xmlns:vm="using:FlexID.ViewModels"
  xmlns:winex="using:WinUIEx"
  Title="{x:Bind ViewModel.Title}"
  Width="500"
  Height="500"
  mc:Ignorable="d">

  <winex:WindowEx.SystemBackdrop>
    <MicaBackdrop />
  </winex:WindowEx.SystemBackdrop>

  <Grid Margin="16" RowSpacing="8">
    <Grid.RowDefinitions>
      <RowDefinition />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>
    <ListView
      ItemsSource="{x:Bind ViewModel.Targets}"
      SelectionChanged="ListView_SelectionChanged"
      SelectionMode="Extended">
      <ListView.ItemTemplate>
        <DataTemplate x:DataType="vm:ProgressTargetViewModel">
          <Grid Padding="0,6" ColumnSpacing="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid Grid.Column="0" Visibility="{x:Bind BoolToVisibility(IsBlocked), Mode=OneWay}">
              <FontIcon Foreground="LightGray" Glyph="&#xF2D9;" />
            </Grid>
            <Grid Grid.Column="0" Visibility="{x:Bind BoolToVisibility(IsRunning), Mode=OneWay}">
              <ProgressRing Width="20" Height="20" />
            </Grid>
            <Grid Grid.Column="0" Visibility="{x:Bind BoolToVisibility(IsSuccess), Mode=OneWay}">
              <FontIcon Foreground="Green" Glyph="&#xF136;" />
              <FontIcon Foreground="LightGreen" Glyph="&#xF137;" />
              <FontIcon Foreground="Black" Glyph="&#xF13E;" />
            </Grid>
            <Grid Grid.Column="0" Visibility="{x:Bind BoolToVisibility(IsFailure), Mode=OneWay}">
              <FontIcon Foreground="DarkRed" Glyph="&#xF136;" />
              <FontIcon Foreground="Red" Glyph="&#xF137;" />
              <FontIcon Foreground="White" Glyph="&#xF13D;" />
            </Grid>
            <TextBlock Grid.Column="1" Text="{x:Bind Title}" />
            <TextBlock
              Grid.Row="1"
              Grid.Column="1"
              Margin="0,4"
              Text="{x:Bind ErrorText, Mode=OneWay}"
              Visibility="{x:Bind BoolToVisibility(IsFailureDetails), Mode=OneWay}" />
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>

    <Button
      Grid.Row="1"
      Width="120"
      Height="40"
      Margin="0,0,24,0"
      HorizontalAlignment="Right"
      Command="{x:Bind ViewModel.AbortOrCloseCommand}"
      Content="{x:Bind GetButtonText(ViewModel.InProgress), Mode=OneWay}" />
  </Grid>

</winex:WindowEx>
