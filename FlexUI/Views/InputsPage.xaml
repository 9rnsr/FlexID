<?xml version="1.0" encoding="utf-8" ?>
<Page
  x:Class="FlexID.Views.InputsPage"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:behaviors="using:CommunityToolkit.WinUI.Behaviors"
  xmlns:controls="using:CommunityToolkit.WinUI.Controls"
  xmlns:converters="using:CommunityToolkit.WinUI.Converters"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:i="using:Microsoft.Xaml.Interactivity"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:v="using:FlexID.Views"
  xmlns:vb="using:FlexID.Views.Behaviors"
  xmlns:vm="using:FlexID.ViewModels"
  mc:Ignorable="d">

  <Page.Resources>
    <Style TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
    </Style>
    <converters:BoolToVisibilityConverter x:Key="BoolToVisibility" />
  </Page.Resources>

  <Grid Grid.Row="0" RowSpacing="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition />
    </Grid.RowDefinitions>

    <Grid ColumnSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition />
      </Grid.ColumnDefinitions>

      <DropDownButton
        Grid.Column="0"
        MinWidth="130"
        VerticalAlignment="Stretch"
        AccessKey="E"
        Content="Elements ...">
        <DropDownButton.Flyout>
          <Flyout
            Closed="ElementsFlyout_Closed"
            Placement="BottomEdgeAlignedLeft"
            ShouldConstrainToRootBounds="False">
            <Flyout.FlyoutPresenterStyle>
              <Style BasedOn="{StaticResource DefaultFlyoutPresenterStyle}" TargetType="FlyoutPresenter">
                <Setter Property="MaxWidth" Value="1000" />
                <Setter Property="MaxHeight" Value="600" />
                <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
                <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
              </Style>
            </Flyout.FlyoutPresenterStyle>
            <Grid IsAccessKeyScope="True" XYFocusKeyboardNavigation="Enabled">
              <!--    -->
            </Grid>
          </Flyout>
        </DropDownButton.Flyout>
      </DropDownButton>

      <DropDownButton
        Grid.Column="1"
        MinWidth="130"
        VerticalAlignment="Stretch"
        AccessKey="I"
        Content="Intake Route">
        <DropDownButton.Flyout>
          <Flyout Placement="BottomEdgeAlignedLeft" ShouldConstrainToRootBounds="False">
            <StackPanel
              IsAccessKeyScope="True"
              KeyTipPlacementMode="Left"
              XYFocusKeyboardNavigation="Enabled">
              <CheckBox AccessKey="J" Content="Injection" />
              <CheckBox AccessKey="G" Content="Ingestion" />
              <CheckBox AccessKey="H" Content="Inhalation" />
              <StackPanel
                Margin="12,0,0,0"
                Spacing="16"
                KeyTipPlacementMode="Bottom"
                Orientation="Horizontal">
                <CheckBox AccessKey="F" Content="F" />
                <CheckBox AccessKey="M" Content="M" />
                <CheckBox AccessKey="S" Content="S" />
                <StackPanel.Resources>
                  <Style BasedOn="{StaticResource DefaultCheckBoxStyle}" TargetType="CheckBox">
                    <Setter Property="MinWidth" Value="0" />
                    <Setter Property="Padding" Value="8,5" />
                  </Style>
                </StackPanel.Resources>
              </StackPanel>
            </StackPanel>
          </Flyout>
        </DropDownButton.Flyout>
      </DropDownButton>

      <TextBox
        Grid.Column="2"
        AccessKey="F"
        PlaceholderText="Search Filter"
        Text="{x:Bind Targets.SearchFilter.Value, UpdateSourceTrigger=PropertyChanged, Mode=TwoWay}" />
    </Grid>

    <ListView
      Grid.Row="1"
      ItemsSource="{x:Bind Targets.FilteredItems}"
      ScrollViewer.HorizontalScrollBarVisibility="Hidden"
      SelectionMode="Extended">

      <ListView.Header>
        <Border
          Background="{ThemeResource SystemControlBackgroundAltHighBrush}"
          BorderBrush="{ThemeResource SystemBaseLowColor}"
          BorderThickness="0,0,0,1">
          <i:Interaction.Behaviors>
            <behaviors:StickyHeaderBehavior />
          </i:Interaction.Behaviors>
          <Border.Resources>
            <Style BasedOn="{StaticResource DefaultDataColumnStyle}" TargetType="controls:DataColumn">
              <Setter Property="Padding" Value="0" />
              <Setter Property="FontSize" Value="12" />
            </Style>
          </Border.Resources>
          <controls:DataTable ColumnSpacing="8">
            <controls:DataColumn DesiredWidth="Auto">
              <CheckBox
                MinWidth="0"
                Margin="16,0,0,0"
                Padding="0"
                IsChecked="{x:Bind Targets.IsCheckedAll, Mode=TwoWay}" />
            </controls:DataColumn>
            <controls:DataColumn Content="Input Title" DesiredWidth="3*" />
            <controls:DataColumn Content="Nuclide" DesiredWidth="Auto" />
            <controls:DataColumn Content="Progenies" DesiredWidth="160" />
          </controls:DataTable>
        </Border>
      </ListView.Header>

      <ListView.ItemTemplate>
        <DataTemplate x:DataType="vm:InputTargetViewModel">
          <controls:DataRow Margin="-16,0,-16,0" HorizontalAlignment="Left">
            <CheckBox
              MinWidth="0"
              Margin="16,0,0,0"
              IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
              IsTabStop="False" />
            <TextBlock VerticalAlignment="Center" Text="{x:Bind Title}" />
            <TextBlock VerticalAlignment="Center" Text="{x:Bind Nuclide}" />
            <DropDownButton
              Width="146"
              MaxWidth="146"
              VerticalAlignment="Center"
              HorizontalContentAlignment="Stretch"
              Visibility="{x:Bind CanCheckProgenies, Converter={StaticResource BoolToVisibility}}">
              <TextBlock
                Text="{x:Bind CheckedProgenies}"
                TextTrimming="CharacterEllipsis"
                TextWrapping="NoWrap" />
              <DropDownButton.Flyout>
                <Flyout Placement="BottomEdgeAlignedLeft">
                  <ListBox ItemsSource="{x:Bind Progenies}">
                    <ListBox.ItemTemplate>
                      <DataTemplate x:DataType="vm:ProgenySelectionViewModel">
                        <CheckBox
                          MinWidth="0"
                          Content="{x:Bind Progeny}"
                          IsChecked="{x:Bind IsChecked}" />
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </Flyout>
              </DropDownButton.Flyout>
            </DropDownButton>
          </controls:DataRow>
        </DataTemplate>
      </ListView.ItemTemplate>

      <i:Interaction.Behaviors>
        <vb:CheckSearchItemsBehavior />
      </i:Interaction.Behaviors>
    </ListView>
  </Grid>

</Page>
