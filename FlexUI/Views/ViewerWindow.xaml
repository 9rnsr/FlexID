            Grid.RowSpan="2"
            Grid.Column="1"
            Margin="0,0,0,60"
            VerticalAlignment="Center"
            ContourMax="{Binding Contour.ContourMax}"
            ContourMin="{Binding Contour.ContourMin}"
            ContourUnit="{Binding Contour.ContourUnit}" />

          <Grid Grid.Row="1" HorizontalAlignment="Stretch">
