              Grid.Row="1"
              Grid.Column="1"
              Width="40"
              Height="32"
              HorizontalAlignment="Center"
              VerticalAlignment="Top"
              Command="{Binding Contour.PreviousStepCommand}"
              Content="&#xF8AC;"
              FontFamily="{StaticResource SymbolThemeFontFamily}"
              FontSize="18"
              ToolTipService.ToolTip="Previous step" />
