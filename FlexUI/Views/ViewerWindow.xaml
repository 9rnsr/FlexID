    <TabView
      x:Name="MainTabControl"
      Grid.RowSpan="2"
      Grid.Column="4"
      HorizontalAlignment="Right"
      VerticalAlignment="Top"
      SelectedIndex="0">
      <!--  Style="{StaticResource MahApps.Styles.TabControl.AnimatedSingleRow}"  -->

      <TabViewItem Header="Model" />
      <TabViewItem Header="Graph" />
    </TabView>

    <!--  Output FilePath  -->
    <Button
      Grid.Column="0"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Center"
      AccessKey="O"
      Command="{x:Bind ViewModel.SelectOutputFilePathCommand}"
      Content="Open"
      ToolTipService.ToolTip="Open Output file (Ctrl+O)" />
    <TextBox
      Grid.Column="1"
      Grid.ColumnSpan="3"
      Padding="6"
      VerticalAlignment="Center"
      DataContext="{x:Bind ViewModel}"
      KeyDown="OutputFilePathTextBox_KeyDown"
      Text="{Binding OutputFilePath, Mode=TwoWay, UpdateSourceTrigger=Explicit}">
      <i:Interaction.Behaviors>
        <!--<vb:PathPasteBehavior />-->
      </i:Interaction.Behaviors>
    </TextBox>

    <!--  Title  -->
    <TextBlock
      Grid.Row="1"
      Grid.Column="0"
      VerticalAlignment="Center"
      Text="Title" />
    <TextBox
      Grid.Row="1"
      Grid.Column="1"
      Grid.ColumnSpan="2"
      AccessKey="L"
      IsReadOnly="True"
      Text="{x:Bind ViewModel.SelectedOutput.Title, Mode=OneWay, FallbackValue=''}" />
    <!--  Style="{StaticResource OutputInfoTextBox}"  -->

    <!--  Output Types  -->
    <TextBlock
      Grid.Row="2"
      Grid.Column="0"
      Text="Output Type" />
    <ComboBox
      Grid.Row="2"
      Grid.Column="1"
      HorizontalAlignment="Stretch"
      AccessKey="T"
      ItemsSource="{x:Bind ViewModel.OutputTypes, Mode=OneWay}"
      SelectedItem="{x:Bind ViewModel.SelectedOutputType, Mode=TwoWay}" />
    <!--  Style="{StaticResource OutputInfoComboBox}"  -->

    <!--  Output Blocks = Nuclides or Male/Female  -->
    <TextBlock
      Grid.Row="3"
      Grid.Column="0"
      VerticalAlignment="Center"
      Text="Nuclides" />
    <ComboBox
      Grid.Row="3"
      Grid.Column="1"
      HorizontalAlignment="Stretch"
      AccessKey="N"
      DisplayMemberPath="Header"
      ItemsSource="{x:Bind ViewModel.SelectedOutput.Blocks, Mode=OneWay}"
      SelectedItem="{x:Bind ViewModel.SelectedBlock, Mode=TwoWay}" />
