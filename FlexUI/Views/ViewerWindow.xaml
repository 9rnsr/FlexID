              x:Name="TimeStepSlider"
              Grid.Row="0"
              Grid.ColumnSpan="5"
              Height="32"
              Margin="70,0"
              d:Maximum="18250"
              d:Minimum="0"
              ToolTipService.Placement="Bottom"
              IsMoveToPointEnabled="True"
              IsSnapToTickEnabled="True"
              Maximum="{Binding Contour.EndTimeStep}"
              Minimum="{Binding Contour.StartTimeStep}"
              Ticks="{Binding Contour.TimeSteps}"
              Value="{Binding Contour.CurrentTimeStep}" />

            <TextBlock
              Grid.Row="1"
              Grid.Column="0"
              HorizontalAlignment="Center"
              Text="{x:Bind TimeStepSlider.Minimum, Mode=OneWay}" />
            <TextBlock
              Grid.Row="1"
              Grid.Column="4"
              HorizontalAlignment="Center"
              Text="{x:Bind TimeStepSlider.Maximum, Mode=OneWay}" />

