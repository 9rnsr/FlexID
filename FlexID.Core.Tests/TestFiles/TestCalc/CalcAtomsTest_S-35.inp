[title]
S-35 Injection

[nuclide]
  S-35  Cl-35

[parameter]
  $S-35/fA    = 0.99 # ≒1  # ICRP Publ.134 p.104 Table 5.3 / Ingested materials, All other forms
  $S-35/fA_Re = 0.99 # ≒1  # footnote††


[intake]
#---------------------+-------------------
# To                  | Transfer Coef.[%]
#---------------------+-------------------

# ICRP Publ.130 p.37 Para.15
  Blood                   100.0%


[S-35:compartment]
#-----+---------------------| S-Coefficient
# Func| Compartment         | Source Region
#-----+---------------------+---------------
  acc   Oralcavity            O-cavity
  acc   Oesophagus-f          Oesophag-f
  acc   Oesophagus-s          Oesophag-s
  acc   St-con                St-cont
  acc   SI-con                SI-cont
  acc   SI-conRe              SI-cont
  acc   RC-con                RC-cont
  acc   LC-con                LC-cont
  acc   RS-con                RS-cont
  acc   Faeces                ---
  acc   UB-con                UB-cont
  acc   Urine                 ---

# ICRP Publ.134 p.108 Fig.5.1 inorganic sulpher
  acc   Blood                 Blood
  acc   Cartilage             Cartilage
  acc   RedMarrow             R-marrow
  acc   Other                 Other

[S-35:transfer]
#-----------------------+---------------------+--------------------
# From                  | To                  | Transfer Coef.[/d]
#-----------------------+---------------------+--------------------

# ICRP Publ.130 p.76 Table 3.4 & footnote
  Oralcavity              Oesophagus-f           6480
  Oralcavity              Oesophagus-s            720
  Oesophagus-f            St-con                12343
  Oesophagus-s            St-con                 2160
  St-con                  SI-con                   20.57
  SI-con                  RC-con                    6
  SI-conRe                RC-con                    6
  RC-con                  LC-con                    2
  LC-con                  RS-con                    2
  RS-con                  Faeces                    2

# λ(SI->Blood) = fA * λ(SI->RC) / (1 - fA)
  SI-con                  Blood                 $(fA    * 6 / (1 - fA   ))
  SI-conRe                Blood                 $(fA_Re * 6 / (1 - fA_Re))

# ICRP Publ.130 p.85 Para.172
  UB-con                  Urine                    12

# ICRP Publ.134 p.108 Table 5.4
  Blood                   RedMarrow                 0.075
  Blood                   Cartilage                 0.25
  Blood                   Other                     0.175
  Blood                   UB-con                    1.8
  Blood                   RC-con                    0.2
  RedMarrow               Blood                     0.3
  Cartilage               Blood                     0.1
  Other                   Blood                     3.5


[Cl-35:compartment]
  acc   X       ---


[Cl-35:transfer]
  S-35/Oralcavity           X       ---
  S-35/Oesophagus-f         X       ---
  S-35/Oesophagus-s         X       ---
  S-35/St-con               X       ---
  S-35/SI-con               X       ---
  S-35/SI-conRe             X       ---
  S-35/RC-con               X       ---
  S-35/LC-con               X       ---
  S-35/RS-con               X       ---
  S-35/Faeces               X       ---
  S-35/UB-con               X       ---
  S-35/Urine                X       ---

# ICRP Publ.134 p.108 Fig.5.1 inorganic sulpher
  S-35/Blood                X       ---
  S-35/Cartilage            X       ---
  S-35/RedMarrow            X       ---
  S-35/Other                X       ---
