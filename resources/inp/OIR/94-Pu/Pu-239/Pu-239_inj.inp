  {*}/C-bone-V            Noch-C-bone-V             ---     # Publ.137 Para.812
  {*}/T-bone-V            Noch-T-bone-V             ---     # Publ.137 Para.812
  {*}/Noch-C-bone-V       Noch-C-bone-V             ---
  {*}/Noch-T-bone-V       Noch-T-bone-V             ---
  {*}/Exch-C-bone-V       Exch-C-bone-V             ---
  {*}/Exch-T-bone-V       Exch-T-bone-V             ---

  {*}/C-marrow            C-marrow                  ---
  {*}/T-marrow            T-marrow                  ---
  {Pu}/Liver0             Plasma                    8.32
  {Pu}/Liver1             Plasma                    8.32
  {Pu}/Liver2             Plasma                    8.32
  {^Pu}/Liver1            Liver1                    ---
  {^Pu}/Liver2            Liver2                    ---
  {*}/Kidneys1            Kidneys1                  ---
  {*}/Kidneys2            Kidneys2                  ---
  {*}/Testes              Testes                    ---
  {*}/Ovaries             Ovaries                   ---
  {*}/Skin                Skin                      ---
  {*}/Spleen              Spleen                    ---

  {U}/ST0                 ST0                       ---
  {U}/ST1                 ST1                       ---
  {U}/ST2                 ST2                       ---
  {^U}/ST0                Plasma                    8.32
  {^U}/ST1                Plasma                    8.32
  {^U}/ST2                Plasma                    8.32
  {*}/Other               Plasma                    8.32


[{Th}:compartment]
#-----+---------------------| S-Coefficient
# Func| Compartment         | Source Region
#-----+---------------------+---------------
  acc   Blood                 Blood
  acc   C-bone-S              C-bone-S
  acc   T-bone-S              T-bone-S
  acc   C-bone-V              C-bone-V
  acc   T-bone-V              T-bone-V
  acc   C-marrow              C-marrow
  acc   T-marrow              T-marrow
  acc   Liver1                Liver         # hepatocytes
  acc   Liver2                Liver         # reticulo-endothelial cells
  acc   Kidneys1              Kidneys       # Urinary path
  acc   Kidneys2              Kidneys       # Other kidney tissues
  acc   Testes                Testes
  acc   Ovaries               Ovaries
  acc   ST0                   Other
  acc   ST1                   Other
  acc   ST2                   Other

#    ICRP Publ.137 p.370 Para.812 / トリウム系列子孫元素としてのトリウムは、ラジウム子孫元素としてのモデルを用いる。
# → ICRP Publ.137 p.333 Para.715 / ラジウム子孫元素としてのトリウム
# > (715) The model for thorium as a progeny of radium is a modification of the systemic
# > model applied in this publication to thorium as a parent radionuclide. Two
# > compartments, one representing spleen and the other representing skin, are added to
# > that model.
# > (715) ラジウムの子孫核種としてのトリウムのモデルは、本論文でトリウムを親核種として
# > 適用した全身モデルを修正したものである。このモデルには、脾臓と皮膚を表す2つの
# > コンパートメントが追加されている。

  acc   Skin                  Skin
  acc   Spleen                Spleen

