[title]
Pb-210 Inhalation:Type-M

[nuclide]
  Pb-210  Bi-210  Hg-206  Po-210  Tl-206

# 崩壊系列
#                    ┌─→ Po-210 ┬→ Pb-206(安定)
# Pb-210 ┬→ Bi-210 ┴┬→ Tl-206 ┘
#        └→ Hg-206 ─┘


[Pb-210:compartment]
#-----+---------------------| S-Coefficient
# Func| Compartment         | Source Region
#-----+---------------------+---------------
  inp   input                 ---

  acc   ET1-F                 ET1-sur
  acc   ET2-F                 ET2-sur
  acc   ETseq-F               ET2-seq
  acc   LNET-F                LN-ET
  acc   BB-F                  Bronchi
  acc   BBseq-F               Bronchi-q
  acc   bb-F                  Brchiole
  acc   bbseq-F               Brchiole-q
  acc   ALV-F                 ALV
  acc   INT-F                 ALV
  acc   LNTH-F                LN-Th
  acc   ET1-S                 ET1-sur
  acc   ET2-S                 ET2-sur
  acc   ETseq-S               ET2-seq
