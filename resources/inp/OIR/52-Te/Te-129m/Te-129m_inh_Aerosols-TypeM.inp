[title]
Te-129m Inhalation, Aerosols Type M

[nuclide]
  Te-129m  Te-129  I-129


[intake]
#---------------------+-------------------
# To                  | Transfer Coef.[%]
#---------------------+-------------------

# ICRP Publ.137 p.73 Table 4.3 / Inhaled particulate materials, Absorption type M
  $fr = 0.2
  $sr = 3
  $ss = 0.005
  $fA    = 0.06
  $fA_Re = 0.3          # footnote¶ (re-absorption)

# ICRP Publ.130 p.62 Table 3.1
# ICRP Publ.130 p.64 Para.98 & p.65 Fig.3.4 footnote
  ET1-F                 $(      fr  *                 47.94% )
  ET2-F                 $(      fr  * (100% - 0.2%) * 25.82% )
  ETseq-F               $(      fr  *         0.2%  * 25.82% )
  BB-F                  $(      fr  * (100% - 0.2%) *  1.78% )
  BBseq-F               $(      fr  *         0.2%  *  1.78% )
  bb-F                  $(      fr  * (100% - 0.2%) *  1.10% )
  bbseq-F               $(      fr  *         0.2%  *  1.10% )
  ALV-F                 $(      fr  *                  5.32% )

  ET1-S                 $( (1 - fr) *                 47.94% )
  ET2-S                 $( (1 - fr) * (100% - 0.2%) * 25.82% )
  ETseq-S               $( (1 - fr) *         0.2%  * 25.82% )
  BB-S                  $( (1 - fr) * (100% - 0.2%) *  1.78% )
  BBseq-S               $( (1 - fr) *         0.2%  *  1.78% )
  bb-S                  $( (1 - fr) * (100% - 0.2%) *  1.10% )
  bbseq-S               $( (1 - fr) *         0.2%  *  1.10% )
  ALV-S                 $( (1 - fr) *                  5.32% )

  Environment           $(                     100% - 81.96% )


